{
  "name": "nitrocss",
  "version": "2.1.0",
  "description": "CSS framework",
  "homepage": "https://github.com/caitlinteaguedesign/nitrocss#readme",
  "bugs": {
    "url": "https://github.com/caitlinteaguedesign/nitrocss/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/caitlinteaguedesign/nitrocss.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "dist/index.html",
  "scripts": {
    "check": "astro check",
    "sass:watch": "sass --watch --stop-on-error nitro-css/project:public/styles",
    "dev": "concurrently -n vite,sass -c gray,cyan \"astro dev\" \"npm run sass:watch\"",
    "sass:build": "sass --stop-on-error --no-source-map --style=compressed nitro-css/project:public/styles",
    "build": "npm run sass:build && astro build",
    "preview": "astro preview"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.2",
    "astro": "^6.1.1",
    "concurrently": "^9.2.1",
    "prettier": "3.8.1",
    "prettier-plugin-astro": "0.14.1",
    "sass": "^1.98.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "npm": "11.6.0",
    "node": "24.8.0"
  }
}
