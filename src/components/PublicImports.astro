---
const baseUrl = import.meta.env.BASE_URL;
---

<!-- main stylesheet built from sass -->
<link rel="stylesheet" href={`${baseUrl}styles/global.css`} />

<!-- jQuery-ui styles -->
<link rel="stylesheet" href={`${baseUrl}scripts/jquery-ui/jquery-ui.min.css`} />

<!-- date/time picker styles -->
<link
  rel="stylesheet"
  href={`${baseUrl}scripts/jquery-datetimepicker/jquery.datetimepicker.min.css`}
/>

<!-- JS -->
<!-- jQuery Library -->
<script is:inline src={`${baseUrl}scripts/jquery-3.2.1.min.js`}></script>

<!-- jQuery UI -->
<script is:inline src={`${baseUrl}scripts/jquery-ui/jquery-ui.min.js`}></script>

<!-- form validation -->
<script is:inline src={`${baseUrl}scripts/parsley.min.js`}></script>

<!-- jQuery DateTimePicker -->
<script
  is:inline
  src={`${baseUrl}scripts/jquery-datetimepicker/jquery.datetimepicker.full.min.js`}
></script>

<!-- jQuery Hover Intent -->
<script is:inline src={`${baseUrl}scripts/jquery.hoverIntent.minified.js`}
></script>

<!-- for forcing IE to play nice and show external svgs linking -->
<script is:inline src={`${baseUrl}scripts/svg4everybody.min.js`}></script>
<script is:inline>
  svg4everybody();
</script>

<!-- Custom -->
<script is:inline src={`${baseUrl}scripts/custom.js`}></script>
<script is:inline src={`${baseUrl}scripts/supermodals.js`}></script>

<!-- highlighting for code examples -->
<link rel="stylesheet" href={`${baseUrl}scripts/highlighter/sunburst.css`} />
<script is:inline src={`${baseUrl}scripts/highlighter/highlight.pack.js`}
></script>
<script is:inline>
  hljs.initHighlightingOnLoad();
</script>
